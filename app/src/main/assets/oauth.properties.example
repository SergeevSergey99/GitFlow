# OAuth Configuration Example
# Copy this file to oauth.properties and fill in your actual credentials
# DO NOT commit the oauth.properties file to git - it's already in .gitignore

# GitHub OAuth App Credentials
# Create app at: https://github.com/settings/applications/new
# Callback URL: gitflow://oauth/callback
github.client.id=your_github_client_id_here
github.client.secret=your_github_client_secret_here

# GitLab OAuth App Credentials
# Create app at: https://gitlab.com/-/profile/applications
# Callback URL: gitflow://oauth/callback
gitlab.client.id=your_gitlab_client_id_here
gitlab.client.secret=your_gitlab_client_secret_here

# Bitbucket OAuth Consumer Credentials
# Create consumer at: https://bitbucket.org/account/settings/app-passwords/
# (Account settings → OAuth → Add consumer)
# Callback URL: gitflow://oauth/callback
bitbucket.client.id=your_bitbucket_client_id_here
bitbucket.client.secret=your_bitbucket_client_secret_here

# ---- PAT-based providers (no app credentials needed) ----
# Gitea / Forgejo: Users enter their instance URL and Personal Access Token in-app.
# Azure DevOps:   Users enter their org URL and Personal Access Token in-app.
